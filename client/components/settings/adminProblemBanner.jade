template(name="adminProblemBanner")
  if hasProblems
    .admin-problem-banner(role="status" aria-live="polite")
      each area in areas
        .admin-problem-item
          i.fa.fa-exclamation-triangle
          span.admin-problem-path {{_ 'admin-panel'}} → {{_ 'reports'}} → {{areaLabel area.stream}}
          span.admin-problem-count {{area.count}} {{_ 'new-problems'}}
          a.js-ack-problems.primary(data-stream="{{area.stream}}") {{_ 'acknowledge'}}
