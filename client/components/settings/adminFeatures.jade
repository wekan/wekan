template(name="adminFeatures")
  .setting-content
    unless currentUser.isAdmin
      | {{_ 'error-notAuthorized'}}
    else
      .content-title.ext-box
        span
          span.emoji-icon
          i.fa.fa-flask
          | {{_ 'features'}}
      .content-body
        .side-menu
          ul
            li(class="{{#if isPerformanceActive}}active{{/if}}")
              a.js-features-menu(data-id="performance")
                span.emoji-icon
                i.fa.fa-tachometer
                | {{_ 'features-performance'}}
            li(class="{{#if isSecurityActive}}active{{/if}}")
              a.js-features-menu(data-id="security")
                span.emoji-icon
                i.fa.fa-shield
                | {{_ 'features-security'}}
        .main-body
          if isPerformanceActive
            ul.setting-detail
              li.layout-form
                .title {{_ 'cards-loading'}}
                .form-group
                  select#cards-loading.js-cards-loading
                    each cardsLoadingOptions
                      if this.selected
                        option(value="{{value}}" selected) {{_ label}}
                      else
                        option(value="{{value}}") {{_ label}}
                p.description {{_ 'cards-loading-description'}}
                p.description {{_ 'cards-loading-lazy-note'}}
          if isSecurityActive
            ul.setting-detail
              li
                a.flex.js-toggle-render-links-as-plain-text
                  .materialCheckBox(class="{{#if renderLinksAsPlainText}}is-checked{{/if}}")
                  span {{_ 'render-links-as-plain-text'}}
                p.description {{_ 'render-links-as-plain-text-description'}}
              li
                a.flex.js-toggle-always-show-code-as-text
                  .materialCheckBox(class="{{#if alwaysShowCodeAsText}}is-checked{{/if}}")
                  span {{_ 'always-show-code-as-text'}}
                p.description {{_ 'always-show-code-as-text-description'}}
              li
                a.flex.js-toggle-disable-all-import
                  .materialCheckBox(class="{{#if disableAllImport}}is-checked{{/if}}")
                  span {{_ 'disable-all-import'}}
                p.description {{_ 'disable-all-import-description'}}
              li
                a.flex.js-toggle-disable-all-export
                  .materialCheckBox(class="{{#if disableAllExport}}is-checked{{/if}}")
                  span {{_ 'disable-all-export'}}
                p.description {{_ 'disable-all-export-description'}}
              li
                a.flex.js-toggle-disable-import-avatars
                  .materialCheckBox(class="{{#if disableImportAvatars}}is-checked{{/if}}")
                  span {{_ 'disable-import-avatars'}}
                p.description {{_ 'disable-import-avatars-description'}}
              li
                a.flex.js-toggle-disable-export-avatars
                  .materialCheckBox(class="{{#if disableExportAvatars}}is-checked{{/if}}")
                  span {{_ 'disable-export-avatars'}}
                p.description {{_ 'disable-export-avatars-description'}}
              li
                a.flex.js-toggle-anonymize-import-users
                  .materialCheckBox(class="{{#if anonymizeImportUsers}}is-checked{{/if}}")
                  span {{_ 'anonymize-import-users'}}
                p.description {{_ 'anonymize-import-users-description'}}
              li
                a.flex.js-toggle-anonymize-export-users
                  .materialCheckBox(class="{{#if anonymizeExportUsers}}is-checked{{/if}}")
                  span {{_ 'anonymize-export-users'}}
                p.description {{_ 'anonymize-export-users-description'}}
