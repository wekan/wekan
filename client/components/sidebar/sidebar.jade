template(name="sidebar")
  .board-sidebar.sidebar(class="{{#if isOpen}}is-open{{/if}} {{#unless isVerticalScrollbars}}no-scrollbars{{/unless}}")
    //- Drag the sidebar's LEFT edge to resize its width (desktop only; hidden on
      mobile where the sidebar is full width). Saved to the user profile (or
      localStorage for anonymous users on a public board).
    .sidebar-resize-handle.js-sidebar-resize-handle.nodragscroll(title="{{_ 'drag-to-resize-sidebar'}}")
    //a.sidebar-tongue.js-toggle-sidebar(
    //
      class="{{#if isTongueHidden}}is-hidden{{/if}}",
    //
      title="{{showTongueTitle}}")
    //
      i.fa.fa-navicon
    .sidebar-actions
      .sidebar-shortcuts
        a.sidebar-btn.js-shortcuts(title="{{_ 'keyboard-shortcuts' }}")
          i.fa.fa-keyboard-o
          span {{_ 'keyboard-shortcuts' }}
        a.sidebar-btn.js-keyboard-shortcuts-toggle(
          title="{{#if isKeyboardShortcuts}}{{_ 'keyboard-shortcuts-enabled'}}{{else}}{{_ 'keyboard-shortcuts-disabled'}}{{/if}}")
          i.fa(class="{{#if isKeyboardShortcuts}}fa-check{{else}}fa-ban{{/if}}")
      if isAccessibilityEnabled
        a.sidebar-accessibility
          i.fa.fa-universal-access
          span {{_ 'accessibility'}}
      a.sidebar-xmark.js-close-sidebar(aria-label="{{_ 'close'}}") &#10005;
    .sidebar-content.js-board-sidebar-content
      //a.hide-btn.js-hide-sidebar
      //
        i.fa.fa-navicon
      unless isDefaultView
        h2
          a.fa.fa-arrow-left.js-back-home(aria-label="{{_ 'go-back'}}")
          = getViewTitle
      if isOpen
        +Template.dynamic(template=getViewTemplate)

template(name='homeSidebar')
  +membersWidget
  hr
  +labelsWidget
  hr
  ul#cards.label-text-hidden
    a.flex.js-toggle-minicard-label-text(title="{{_ 'hide-minicard-label-text'}}")
      i.fa(class="{{#if hiddenMinicardLabelText}}fa-check{{else}}fa-square-o{{/if}}")
      span {{_ 'hide-minicard-label-text'}}
  if currentUser
    ul#cards.vertical-scrollbars-toggle
      a.flex.js-vertical-scrollbars-toggle(title="{{_ 'enable-vertical-scrollbars'}}")
        i.fa(class="{{#if isVerticalScrollbars}}fa-check{{else}}fa-square-o{{/if}}")
        span {{_ 'enable-vertical-scrollbars'}}
  ul#cards.show-week-of-year-toggle
    a.flex.js-show-week-of-year-toggle(title="{{_ 'show-week-of-year'}}")
      i.fa(class="{{#if isShowWeekOfYear}}fa-check{{else}}fa-square-o{{/if}}")
      span {{_ 'show-week-of-year'}}
  hr
  if currentUser.isBoardAdmin
    h3.activity-title
      i.fa.fa-comment-o
      | {{_ 'activities'}}

      if showActivities
        a.flex.activities-eye-toggle.js-toggle-show-activities(title="{{_ 'hide-activities'}}" aria-label="{{_ 'hide-activities'}}")
          i.fa.fa-eye.eye-icon
          span {{_ 'hide-activities'}}
      else
        a.flex.activities-eye-toggle.js-toggle-show-activities(title="{{_ 'show-activities'}}" aria-label="{{_ 'show-activities'}}")
          i.fa.fa-eye-slash.eye-slash-icon
          span {{_ 'show-activities'}}
    +activities(mode="board")

template(name="membersWidget")
  unless currentUser.isCommentOnly
    unless currentUser.isWorker
      h3
        a.board-header-btn.js-open-board-menu(title="{{_ 'boardMenuPopup-title'}}")
          i.fa.fa-cog
          | {{_ 'boardMenuPopup-title'}}
  hr
  h3
    i.fa.fa-users
    | {{_ 'members'}}
  +basicTabs(tabs=tabs)
      +tabContent(slug="people")
        unless currentUser.isWorker
          p.quiet
        .board-widget-content
          if currentBoard.isAnyTemplateBoard
            +userAvatar(userId=currentBoard.userId showStatus=true)
            .clearfix
          else
            each currentBoard.membersForSidebar
              +userAvatar(userId=this.userId showStatus=true)
            if isSandstorm
              if currentUser.isBoardMember
                a.member.add-member.sandstorm-powerbox-request-identity(title="{{_ 'add-members'}}")
                  i.fa.fa-plus
            else if currentUser.canInviteToBoard
              a.member.add-member.js-manage-board-members(title="{{_ 'add-members'}}")
                i.fa.fa-plus
            .clearfix
            if isInvited
              hr
              p
                i.fa.fa-exclamation-triangle
                | {{_ 'just-invited'}}
              button.js-member-invite-accept.primary {{_ 'accept'}}
              button.js-member-invite-decline {{_ 'decline'}}
      +tabContent(slug='organizations')
        unless currentUser.isWorker
          p.quiet
        .board-widget-content
          +boardOrgGeneral
          .clearfix
      +tabContent(slug="teams")
        unless currentUser.isWorker
          p.quiet
        .board-widget-content
          +boardTeamGeneral
          .clearfix
      +tabContent(slug="domains")
        unless currentUser.isWorker
          p.quiet
        .board-widget-content
          +boardDomainGeneral
          .clearfix

template(name="boardOrgGeneral")
  each org in currentBoard.activeOrgs
    +boardOrgRow(orgId=org.orgId)
  if currentUser.isBoardAdmin
    a.member.orgOrTeamMember.add-member.js-manage-board-addOrg(title="{{_ 'add-members'}}")
      i.fa.fa-plus

template(name="boardTeamGeneral")
  each currentBoard.activeTeams
    +boardTeamRow(teamId=this.teamId)
  if currentUser.isBoardAdmin
    a.member.orgOrTeamMember.add-member.js-manage-board-addTeam(title="{{_ 'add-members'}}")
      i.fa.fa-plus

template(name="boardDomainGeneral")
  each currentBoard.activeDomains
    +boardDomainRow(domain=this.domain)
  if currentUser.isBoardAdmin
    a.member.orgOrTeamMember.add-member.js-manage-board-addDomain(title="{{_ 'add-domain'}}")
      i.fa.fa-plus

template(name="boardDomainRow")
  a.member.orgOrTeamMember.js-manage-board-removeDomain(title="{{domain}}" data-domain="{{domain}}")
    svg.avatar.avatar-initials(viewBox="0 0 {{domainViewPortWidth}} 15")
      text(x="50%" y="11" text-anchor="middle" dominant-baseline="middle" font-size="16")= domain

template(name="boardChangeColorPopup")
  //- docs/Theme/Theme.md: category + theme dropdowns with custom color wheels for
    the flat/clear categories, shared with Member Settings / Change Color.
  +themeColorPicker(scope="board")

template(name="boardBackgroundsPopup")
  .board-backgrounds-manage
    input.js-bg-upload-input.hide(type="file" name="file" accept="image/*")
    a.primary.wide.js-bg-upload-button
      i.fa.fa-plus
      = ' '
      | {{_ 'upload-background'}}
    if uploading.get
      +spinner
    if error.get
      .warning {{_ error.get}}
    .board-backgrounds-grid.clearfix
      each backgrounds
        .board-bg-item(class="{{#if isActiveBackground}}is-active{{/if}}")
          .board-bg-thumb(style="background-image: url('{{link}}');")
            if isActiveBackground
              i.fa.fa-check.board-bg-active-check
          .board-bg-actions
            unless isActiveBackground
              a.js-set-board-background(title="{{_ 'set-as-active'}}")
                i.fa.fa-check-circle-o
            a.js-download-board-background(href="{{link}}?download=true" download="{{name}}" title="{{_ 'download'}}")
              i.fa.fa-arrow-down
            a.js-delete-board-background(title="{{_ 'delete'}}")
              i.fa.fa-trash-o

template(name="deleteBoardBackgroundPopup")
  p {{_ 'board-background-delete-pop'}}
  button.js-confirm.negate.full(type="submit")
    i.fa.fa-trash-o
    | {{_ 'delete'}}

template(name="boardChangeBackgroundImagePopup")
  form
    label
      | {{_ 'board-background-image-url'}}
      input.js-board-background-image-url(type="text" value="{{backgroundImageURL}}" autofocus)
    div.buttonsContainer
      input.primary.wide(type="submit" value="{{_ 'save'}}")
    br
    br
    br
    br
    br
    hr
    div
      button.js-remove-background-image.negate.wide.card-details-red.right {{_ 'unset-color'}}

template(name="boardInfoOnMyBoardsPopup")
  form.board-info-on-my-boards
    h3 {{_ 'show-at-all-boards-page'}}
    unless currentSetting.hideCardCounterList
      div.check-div
        a.flex.js-field-has-cardcounterlist(class="{{#if allowsCardCounterList}}is-checked{{/if}}")
          i.fa(class="{{#if allowsCardCounterList}}fa-check{{else}}fa-square-o{{/if}}")
          span
            i.fa.fa-sign-in
            | {{_ 'show-card-counter-per-list'}}
    div.check-div
      a.flex.js-field-has-cardaging(class="{{#if cardAging}}is-checked{{/if}}")
        i.fa(class="{{#if cardAging}}fa-check{{else}}fa-square-o{{/if}}")
        span
          i.fa.fa-clock-o
          | {{_ 'card-aging'}}
      if cardAging
        div.card-aging-days
          span {{_ 'card-aging-days'}}
          input.js-card-aging-days(type="number" min="1" value="{{cardAgingDays1}}" title="{{_ 'card-aging-tier1'}}")
          input.js-card-aging-days(type="number" min="1" value="{{cardAgingDays2}}" title="{{_ 'card-aging-tier2'}}")
          input.js-card-aging-days(type="number" min="1" value="{{cardAgingDays3}}" title="{{_ 'card-aging-tier3'}}")
    unless currentSetting.hideBoardMemberList
      div.check-div
        a.flex.js-field-has-boardmemberlist(class="{{#if allowsBoardMemberList}}is-checked{{/if}}")
          i.fa(class="{{#if allowsBoardMemberList}}fa-check{{else}}fa-square-o{{/if}}")
          span
            i.fa.fa-hourglass
            | {{_ 'show-board_members-avatar'}}
    div.check-div
      a.flex.js-field-has-personal-list-width(title="{{_ 'personal-list-width-description'}}" class="{{#if allowsPersonalListWidth}}is-checked{{/if}}")
        i.fa(class="{{#if allowsPersonalListWidth}}fa-check{{else}}fa-square-o{{/if}}")
        span
          i.fa.fa-arrows-h
          | {{_ 'personal-list-width'}}

