template(name="dependencyOverlay")
  svg.dependency-overlay.js-dependency-overlay(xmlns="http://www.w3.org/2000/svg")
    defs
      each dependencyMarkers
        marker(id="{{markerId}}" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto" markerUnits="userSpaceOnUse")
          path(d="M0,0 L7,3 L0,6 Z" fill="{{color}}")
    each dependencyLines
      path.dependency-line(d="{{path}}" fill="none" stroke="{{color}}" stroke-width="2" marker-end="{{markerUrl}}")
    if tempLine
      path.dependency-temp-line(d="{{tempLine}}" fill="none" stroke="#eb144c" stroke-width="2" stroke-dasharray="6,4")

template(name="dependencyLinePopup")
  .dependency-line-popup
    label.dependency-field
      span {{_ 'dependency-type'}}
      select.js-line-type
        each typeOption
          if selected
            option(value="{{id}}" selected="selected") {{_ label}}
          else
            option(value="{{id}}") {{_ label}}
    label.dependency-field
      span {{_ 'dependency-color'}}
      input.js-line-color(type="color" value="{{color}}")
    .dependency-field
      span {{_ 'dependency-icon'}}
    ul.card-dependency-icons
      each dependencyIcons
        li
          a.js-line-icon(data-icon="{{name}}" title="{{name}}" class="{{#if selected}}is-selected{{/if}}")
            i.fa(class="fa-{{name}}")
    hr
    a.js-line-delete.dependency-line-delete
      i.fa.fa-times
      | {{_ 'remove-dependency'}}
