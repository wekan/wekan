template(name="swimlane")
  .swimlane.nodragscroll
    +swimlaneHeader
  unless collapseSwimlane
    .swimlane.js-lists.js-swimlane.dragscroll(id="swimlane-{{_id}}"
                                   style="height:{{swimlaneHeight}};")
      .swimlane-resize-handle.js-swimlane-resize-handle.nodragscroll
      if isMiniScreen
        if currentListIsInThisSwimlane _id
          +list(currentList)
        unless currentList
          if currentUser.isBoardMember
            unless currentUser.isCommentOnly
              +addListForm
          each lists
            +miniList(this)
      else
        //- #6465: no standing Add List column. Empty swimlane gets the inline
        //- composer at the start; otherwise it opens after a list via its header
        //- add-list button (see isAddListAfter).
        if swimlaneHasNoLists
          if currentUser.isBoardMember
            unless currentUser.isCommentOnly
              //- #6465: an empty swimlane shows only a + button; the create-list
              //- form appears only after it is clicked. (Non-empty swimlanes use
              //- the per-list-header add-list button instead.)
              if isEmptyAddListOpen _id
                +addListInline
              else
                .list.list-composer.js-list-composer.js-empty-add-list-button(class="{{#if isMiniScreen}}mini-list{{/if}}")
                  .list-header-add
                    a.open-list-composer.js-open-empty-add-list(title="{{_ 'add-list'}}" data-swimlane="{{_id}}")
                      i.fa.fa-plus
        each lists
          if visible this
            +list(this)
          if isAddListAfter _id
            +addListInline
          if currentCardIsInThisList _id ../_id
            +cardDetails(currentCard)

template(name="listsGroup")
  .swimlane.list-group.js-lists.dragscroll
    if isMiniScreen
      if currentList
        +list(currentList)
      else
        //- Issue #6142: allow adding a list in Lists (board-view-lists) mode too.
        if defaultSwimlane
          if currentUser.isBoardMember
            unless currentUser.isCommentOnly
              +addListForm(defaultSwimlane)
        each lists
          +miniList(this)
    else
      //- #6465: Lists view — empty board gets the inline composer at the start;
      //- otherwise it opens after a list via that list's header add-list button.
      if boardHasNoLists
        if defaultSwimlane
          if currentUser.isBoardMember
            unless currentUser.isCommentOnly
              //- #6465: empty board shows only a + button; the create-list form
              //- appears only after clicking it.
              if isEmptyAddListOpen defaultSwimlane._id
                +addListInline(defaultSwimlane)
              else
                .list.list-composer.js-list-composer.js-empty-add-list-button(class="{{#if isMiniScreen}}mini-list{{/if}}")
                  .list-header-add
                    a.open-list-composer.js-open-empty-add-list(title="{{_ 'add-list'}}" data-swimlane="{{defaultSwimlane._id}}")
                      i.fa.fa-plus
      each lists
        if visible this
          +list(this)
        if isAddListAfter _id
          +addListInline(defaultSwimlane)
        if currentCardIsInThisList _id null
          +cardDetails(currentCard)

template(name="addListForm")
  unless currentUser.isWorker
    unless currentUser.isCommentOnly
      unless currentUser.isReadOnly
        unless currentUser.isReadAssignedOnly
          .list.list-composer.js-list-composer(class="{{#if isMiniScreen}}mini-list{{/if}}")
        .list-header-add
          +inlinedForm(autoclose=false)
            input.list-name-input.full-line(type="text" placeholder="{{_ 'add-list'}}"
              autocomplete="off" autofocus)
            if swimlaneLists.length
              | {{_ 'add-after-list'}}
              select.list-position-input.full-line
                each swimlaneLists
                  option(value="{{_id}}") {{title}}
            .edit-controls.clearfix
              button.primary.confirm(type="submit") {{_ 'save'}}
              .js-close-inlined-form
                i.fa.fa-times-thin
              unless currentBoard.isTemplatesBoard
                unless currentBoard.isTemplateBoard
                  span.quiet
                    | {{_ 'or'}}
                    a.js-list-template {{_ 'template'}}
          else
            a.open-list-composer.js-open-inlined-form(title="{{_ 'add-list'}}")
              i.fa.fa-plus

//- #6465: always-open inline Add List composer, rendered AFTER a list (right in
//- LTR / left in RTL, via the flex-row lists lane) when that list's header
//- add-list button is clicked, or at the start of an empty swimlane/board.
template(name="addListInline")
  .list.list-composer.js-list-composer.js-add-list-inline(class="{{#if isMiniScreen}}mini-list{{/if}}")
    .list-header-add
      form.js-add-list-inline-form
        input.list-name-input.full-line(type="text" placeholder="{{_ 'add-list'}}"
          autocomplete="off" autofocus)
        //- #6465 follow-up: restore the previous "add after which list"
        //- position selector, pre-selecting the list whose header button opened
        //- this composer, so the position can still be chosen explicitly.
        if swimlaneLists.length
          | {{_ 'add-after-list'}}
          select.list-position-input.full-line
            each swimlaneLists
              option(value="{{_id}}" selected="{{#if isDefaultAfterList _id}}selected{{/if}}") {{title}}
        .edit-controls.clearfix
          button.primary.confirm(type="submit") {{_ 'save'}}
          a.js-close-add-list-inline(title="{{_ 'close'}}")
            i.fa.fa-times-thin
          unless currentBoard.isTemplatesBoard
            unless currentBoard.isTemplateBoard
              span.quiet
                | {{_ 'or'}}
                a.js-list-template {{_ 'template'}}

template(name="moveSwimlanePopup")
  if currentUser
    unless currentUser.isWorker
      label(for='move-swimlane-title') {{_ 'title'}}:
      input#move-swimlane-title.full-line(type="text" value="{{title}}" autofocus)
      label {{_ 'boards'}}:
      select.js-select-boards(autofocus)
        each toBoard in toBoards
          option(value="{{toBoard._id}}" selected="{{#if isSelectedBoard toBoard._id}}selected{{/if}}") {{toBoard.title}}

      label {{_ 'swimlanes'}}:
      select.js-select-swimlanes
        each swimlane in toSwimlanes
          option(value="{{swimlane._id}}" selected="{{#if isSelectedSwimlane swimlane._id}}selected{{/if}}") {{swimlane.title}}

      div
        input(type="radio" name="swimlane-position" value="above" checked id="swimlane-position-above" style="display: inline")
        label(for="swimlane-position-above") {{_ 'above-selected-swimlane'}}
      div
        input(type="radio" name="swimlane-position" value="below" id="swimlane-position-below" style="display: inline")
        label(for="swimlane-position-below") {{_ 'below-selected-swimlane'}}

      .edit-controls.clearfix
        button.primary.confirm.js-done {{_ 'done'}}

