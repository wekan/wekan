# REQUIRED:
# - CloudFlare/WeKan Domain
#   - Speed/Settings: Disable only "HTTP/2 to Origin"
#   - Caching/Overview: Development Mode, Temporarily bypass cache
# - See screenshots at cloudflare directory

{
	# Using below "servers {protocols h1}" to force Caddy to use only
        # HTTP/1.1 -protocol (h1) at background connections,
	# to prevent multitenancy round robin bug, see multitenancy.md
	servers {
		protocols h1
	}
}


# Redirecting http to https

(redirect) {
	@http {
		protocol http
	}
	redir @http https://{host}{uri}
}

## Hosting examples

# 1) WeKan hosting: Custom Domain with default Let's Encrypt TLS certificate
# - at CloudFlare DNS there is grey cloud, no CloudFlare proxy
# - Customer DNS: wekan.company.com CNAME customer.wekan.team
# - WeKan hosting CloudFlare DNS: customer.wekan.team A Server-IPv4-Address

wekan.customer.com {
	# b) No custom domain, using customer.wekan.team:
	#   - Using CloudFlare TLS Origin Certificate with Strict Enforcement
	#   - At CloudFlare DNS change to orange cloud, with CloudFlare proxy,
	#   - ../../../../../Webserver/Caddy.md
	# tls {
	#     load /etc/caddy/certs
	# }
	header {
		-Content-Security-Policy-Report-Only
		-Content-Security-Policy
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https://static.cloudflareinsights.com https://accounts.google.com https://apis.google.com; worker-src 'self' blob:; connect-src 'self' wss://wekan.customer.com https://wekan.customer.com https://cloudflareinsights.com https://accounts.google.com; img-src 'self' data: https://*.googleusercontent.com; frame-src 'self' https://accounts.google.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:;"
		Cross-Origin-Opener-Policy "same-origin-allow-popups"
		X-Content-Type-Options nosniff
		Strict-Transport-Security "max-age=31536000;"
		-X-Frame-Options
		Cache-Control "no-cache, no-store, must-revalidate"
	}
	handle /.well-known/* {
		header Content-Type application/json
		header Access-Control-Allow-Origin *
	}
	handle {
		reverse_proxy 127.0.0.1:3001
	}
}

## 2) WeKan hosting: No custom domain, using customer.wekan.team:
# - Using CloudFlare TLS Origin Certificate with Strict Enforcement
# - At CloudFlare DNS change to orange cloud, with CloudFlare proxy,
# - ../../../../../Webserver/Caddy.md
# - Difference is additional tls section: tls { load /etc/caddy/certs }

customer.wekan.team {
	tls {
		load /etc/caddy/certs
	}
	header {
		-Content-Security-Policy-Report-Only
		-Content-Security-Policy
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https://static.cloudflareinsights.com https://accounts.google.com https://apis.google.com; worker-src 'self' blob:; connect-src 'self' wss://customer.wekan.team https://customer.wekan.team https://cloudflareinsights.com https://accounts.google.com; img-src 'self' data: https://*.googleusercontent.com; frame-src 'self' https://accounts.google.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:;"
		Cross-Origin-Opener-Policy "same-origin-allow-popups"
		X-Content-Type-Options nosniff
		Strict-Transport-Security "max-age=31536000;" 
		-X-Frame-Options
		Cache-Control "no-cache, no-store, must-revalidate"
	}
	handle /.well-known/* {
		header Content-Type application/json
		header Access-Control-Allow-Origin *
	}

	handle {
		reverse_proxy 127.0.0.1:3002
	}
}

# 3) Static website

# 3.1) Static Website: Let's Encrypt TLS
customer.com {
	root * /data/websites/customer.com
	file_server
}

# 3.2) Static Website: CloudFlare TLS
customer.com {
	tls {
		load /etc/caddy/certs
	}
	root * /data/websites/customer.com
	file_server
}

# 4) Example of Sandstorm https://sandstorm.org web hosting
# - with WordPress, Hacker CMS, etc
# - ../../../Sandstorm/Sandstorm.md

# 4.1) Using Let's Encrypt: WordPress, Hacker CMS, etc
customer.fi {
	reverse_proxy 127.0.0.1:81
}

# 4.2) Using CloudFlare TLS: WordPress, Hacker CMS, etc
blog.wekan.fi {
	tls {
		load /etc/caddy/certs
	}
	reverse_proxy 127.0.0.1:81
}

# 4.3) Sandstorm backup: /opt/backup.sh
#
# #!/bin/bash
# sandstorm stop
# tar -cf sandstorm-backup-$(date -I).tar /opt/sandstorm
# sandstorm start

# 4.4) Sandstorm config: /opt/sanstorm/sandstorm.conf
#
# SERVER_USER=sandstorm
# PORT=81
# MONGO_PORT=6081
# BIND_IP=127.0.0.1
# BASE_URL=https://wekan.dev
# WILDCARD_HOST=*.wekan.dev
# UPDATE_CHANNEL=dev
# ALLOW_DEV_ACCOUNTS=false
# SMTP_LISTEN_PORT=25
###### OLD, NOT IN USE:
### SANDCATS_BASE_DOMAIN=sandcats.io
### HTTPS_PORT=443

# 5) PHP/MySQL Wordpress

customer.com {
	tls {
		load /etc/caddy/certs
	}
	root * /data/websites/customer.com
	encode gzip
	file_server
	php_fastcgi unix//run/php/php-fpm.sock

	@disallowed {
		path /xmlrpc.php
		path *.sql
		path /wp-content/uploads/*.php
	}

	rewrite @disallowed '/index.php'
}

# 6) Kanboard

# 6.1) Let's Encrypt TLS

kanboard.customer.com {
	root * /data/websites/kanboard.customer.com
	encode gzip
	php_fastcgi unix//run/php/php-fpm.sock
	try_files {path} {path}/ /index.php?{query}
	file_server
	log {
		output file /var/log/caddy/kanboard_access.log
	}
}

# 6.2) CloudFlare TLS

kanboard.customer.com {
	tls {
		load /etc/caddy/certs
	}
	root * /data/websites/kanboard.customer.com
	encode gzip
	php_fastcgi unix//run/php/php-fpm.sock
	try_files {path} {path}/ /index.php?{query}
	file_server
	log {
		output file /var/log/caddy/kanboard_access.log
	}
}

# 7) Hesk Helpdesk

# 7.1) Let's Encrypt

hesk.customer.com {
	root * /data/websites/hesk.customer.com
	encode zstd gzip
	php_fastcgi unix//run/php/php-fpm.sock
	file_server
	log {
	    output file /var/log/caddy/hesk_access.log
	}
}

# 7.1) CloudFlare TLS

hesk.customer.com {
	tls {
		load /etc/caddy/certs
	}
	root * /data/websites/hesk.customer.com
	encode zstd gzip
	php_fastcgi unix//run/php/php-fpm.sock
	file_server
	log {
	    output file /var/log/caddy/hesk_access.log
	}
}

