{
  "name": "wekan",
  "version": "v9.73.0",
  "description": "Open-Source kanban",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wekan/wekan.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wekan/wekan/issues"
  },
  "homepage": "https://wekan.fi",
  "meteor": {
    "mainModule": {
      "client": "client/main.js",
      "server": "server/main.js"
    },
    "modern": true
  },
  "scripts": {
    "test": "meteor test --once --driver-package meteortesting:mocha",
    "test:unit:node": "node tests/filenameSanitizer.test.cjs && node tests/cardBoardConsistency.test.cjs && node tests/restArrayParam.test.cjs && node tests/minicardLabelHeight.test.cjs && node tests/dateUtils.normalizeDigits.test.cjs && node tests/unit/resetPasswordEmail.test.js",
    "test:unit:all": "npm run test:unit:node && node tests/cards.stickers.test.js && node tests/stickers.test.js && node tests/stickers.packs.test.js && node tests/linkCardPopup.test.js && node tests/trelloCreator.import.test.js && node tests/trelloImport.maplink.test.js && node tests/trelloImport.zip.test.js && node tests/wekanCreator.import.test.js && node tests/wekanCreator.inconsistent.test.js && node tests/unit/oauth2-admin-groups.test.js",
    "test:watch": "meteor test --driver-package meteortesting:mocha",
    "test:e2e": "node tests/e2e/list-regressions.js",
    "test:playwright": "cd tests/playwright && npm install && npx playwright test",
    "test:playwright:ui": "cd tests/playwright && npx playwright test --ui",
    "test:playwright:all": "cd tests/playwright && WEKAN_PLAYWRIGHT_ALL=1 npx playwright test --project=chromium --project=firefox --project=webkit",
    "test:playwright:report": "cd tests/playwright && npx playwright show-report",
    "playwright:install": "cd tests/playwright && npx playwright install --with-deps"
  },
  "devDependencies": {
    "@meteorjs/rspack": "^2.0.1",
    "@rsdoctor/rspack-plugin": "^1.5.7",
    "@rspack/cli": "^1.7.11",
    "@rspack/core": "^1.7.11",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.60.1",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "css-loader": "^7.1.4",
    "mongodb": "^7.3.0",
    "puppeteer": "^25.0.4",
    "sinon": "^22.0.0",
    "sinon-chai": "^4.0.1",
    "style-loader": "^4.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1071.0",
    "@azure/storage-blob": "^12.32.0",
    "@babel/parser": "^7.29.2",
    "@babel/runtime": "^7.29.2",
    "@google-cloud/storage": "^7.21.0",
    "@meteorjs/reify": "^0.25.4",
    "@rwap/jquery-ui-touch-punch": "^1.0.11",
    "@swc/helpers": "^0.5.23",
    "@textcomplete/contenteditable": "^0.1.13",
    "@textcomplete/core": "^0.1.13",
    "@textcomplete/textarea": "^0.1.13",
    "@tweedegolf/sab-adapter-amazon-s3": "^1.0.20",
    "@tweedegolf/sab-adapter-azure-blob": "^3.0.2",
    "@tweedegolf/sab-adapter-google-cloud": "^3.0.2",
    "@wekanteam/dragscroll": "^0.0.9",
    "@wekanteam/exceljs": "^4.7.3",
    "@wekanteam/html-to-markdown": "^1.0.3",
    "@wekanteam/meteor-globals": "^1.1.6",
    "@wekanteam/meteor-reactive-cache": "^1.0.8",
    "autosize": "^6.0.1",
    "bson": "^7.3.0",
    "dompurify": "^3.4.11",
    "escape-string-regexp": "^5.0.0",
    "filesize": "^11.0.13",
    "glob": "^13.0.6",
    "hotkeys-js": "^4.0.2",
    "i18next": "^26.3.4",
    "i18next-sprintf-postprocessor": "^0.2.2",
    "jquery": "^3.7.1",
    "jquery-ui": "^1.14.2",
    "jszip": "^3.7.1",
    "limax": "^4.2.3",
    "markdown-it": "^14.1.1",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-math": "^6.0.0",
    "meteor-accounts-t9n": "^2.6.0",
    "meteor-node-stubs": "file:npm-packages/meteor-node-stubs",
    "papaparse": "^5.5.4",
    "pretty-ms": "^9.3.0",
    "temml": "^0.13.3",
    "underscore": "^1.13.8"
  },
  "overrides": {
    "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.4.15",
    "elliptic": "^6.6.1",
    "archiver-utils": {
      "glob": "$glob"
    },
    "uuid": "^14.0.0",
    "webpack-dev-server": "^5.2.5"
  }
}
