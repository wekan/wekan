#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# One-time MongoDB → FerretDB v1 (SQLite) migration for the WeKan snap.
#
# Runs on startup (called by wekan-control) BEFORE WeKan starts. When upgrading
# an old MongoDB-based WeKan snap to this FerretDB-based one, it:
#   1. detects existing MongoDB data in $SNAP_COMMON,
#   2. starts the right bundled mongod to read it — mongod 7 for MongoDB 7 data
#      (all arches, incl. arm64), or the bundled old mongod 3.x for the amd64
#      WeKan 6.09 (MongoDB 3.2) data,
#   3. starts a temporary FerretDB v1 (SQLite),
#   4. runs migrate-mongodb-to-ferretdb.mjs, which copies text data to FerretDB,
#      moves attachments/avatars from GridFS to the filesystem, shows progress at
#      ROOT_URL, checkpoints to $SNAP_COMMON (resumable), and compacts the old
#      MongoDB when done,
#   5. switches the snap to `database=ferretdb`.
#
# Safe: idempotent (a completion marker short-circuits it), resumable, never
# deletes the source MongoDB data, and only switches to FerretDB on success.
#
# IMPORTANT: This orchestration has NOT been exercised end-to-end against a real
# 6.09 snap here. In particular, running the 2016-era mongod 3.2 binary on a
# modern (core24) base may need extra runtime libraries. Test on a copy first.
# ─────────────────────────────────────────────────────────────────────────────
set -u

if [[ "${PATH:-}" != *"${SNAP_INSTANCE_NAME:-wekan}"* ]]; then
  export PATH="${PATH/\/snap\/wekan\//\/snap\/${SNAP_INSTANCE_NAME:-wekan}\/}"
fi

MARKER="$SNAP_COMMON/.migration-to-ferretdb-done"
DBPATH="$SNAP_COMMON"                       # old snap's mongod --dbpath
SRC_PORT=27099                              # temp source mongod
TGT_PORT=27098                              # temp target FerretDB
NODE="$SNAP/bin/node"
MIGRATOR="$SNAP/bin/migrate-mongodb-to-ferretdb.mjs"
FERRETDB="$SNAP/ferretdb"
SQLITE_DIR="$SNAP_COMMON/ferretdb-sqlite"
MONGOSH="$SNAP/bin/mongosh"

log() { echo "[migration] $*"; }

# Already migrated, or no tools to migrate with → nothing to do.
[ -f "$MARKER" ] && { log "already migrated (marker present)."; exit 0; }
# Only migrate if there is old MongoDB (WiredTiger) data present.
if [ ! -f "$DBPATH/WiredTiger" ] && ! ls "$DBPATH"/collection-*.wt >/dev/null 2>&1; then
  log "no existing MongoDB data in $DBPATH; nothing to migrate."
  touch "$MARKER" 2>/dev/null || true
  exit 0
fi
if [ ! -x "$FERRETDB" ] || [ ! -x "$NODE" ] || [ ! -f "$MIGRATOR" ]; then
  log "ERROR: migration tools missing (ferretdb/node/migrator); leaving MongoDB in place."
  exit 0   # do not block WeKan; a mongod-based run can still work if configured
fi

export LC_ALL=C
export LD_LIBRARY_PATH="$SNAP/lib:$SNAP/lib/x86_64-linux-gnu:$SNAP/lib/aarch64-linux-gnu:${LD_LIBRARY_PATH:-}"

# ── Pick the mongod that can open the existing data ──────────────────────────
# mongod 7 opens MongoDB 6/7 data (arm64 always lands here). For the amd64 6.09
# (MongoDB 3.2) data, mongod 7 refuses to start, so fall back to the bundled old
# mongod ($SNAP/bin/mongod-old, amd64 only).
LOGF="$SNAP_COMMON/migration-mongod.log"
start_mongod() {   # $1 = mongod binary
  "$1" --dbpath "$DBPATH" --bind_ip 127.0.0.1 --port "$SRC_PORT" \
       --logpath "$LOGF" --logappend --fork >/dev/null 2>&1
}
mongod_ok() {
  local i=0
  while [ $i -lt 20 ]; do
    "$MONGOSH" --port "$SRC_PORT" --quiet --eval 'db.adminCommand({ping:1}).ok' 2>/dev/null | grep -q 1 && return 0
    i=$((i+1)); sleep 1
  done
  return 1
}
stop_mongod() {
  "$MONGOSH" --port "$SRC_PORT" --quiet --eval 'db.getSiblingDB("admin").shutdownServer()' >/dev/null 2>&1 || true
  sleep 2
}

SRC_MONGOD=""
log "Trying mongod 7 on the existing data ..."
if start_mongod "$SNAP/bin/mongod" && mongod_ok; then
  SRC_MONGOD="$SNAP/bin/mongod"
  log "mongod 7 opened the data (MongoDB 6/7)."
else
  stop_mongod
  if [ -x "$SNAP/bin/mongod-old" ]; then
    log "mongod 7 could not open it; trying the bundled old mongod (MongoDB 3.x, amd64) ..."
    if start_mongod "$SNAP/bin/mongod-old" && mongod_ok; then
      SRC_MONGOD="$SNAP/bin/mongod-old"
      log "old mongod opened the data (MongoDB 3.x)."
    else
      stop_mongod
    fi
  fi
fi

if [ -z "$SRC_MONGOD" ]; then
  log "ERROR: could not open the existing MongoDB data with any bundled mongod."
  log "See $LOGF . Leaving data in place and NOT switching to FerretDB."
  exit 0
fi

# ── Start a temporary FerretDB (SQLite) as the migration target ──────────────
mkdir -p "$SQLITE_DIR"
export DO_NOT_TRACK=1 FERRETDB_TELEMETRY=disable
"$FERRETDB" --handler=sqlite --sqlite-url="file:$SQLITE_DIR/" \
            --listen-addr="127.0.0.1:$TGT_PORT" --telemetry=disable \
            >"$SNAP_COMMON/migration-ferretdb.log" 2>&1 &
FERRET_PID=$!
trap 'kill "$FERRET_PID" 2>/dev/null || true; stop_mongod' EXIT INT TERM

# ── Run the migrator (progress served at ROOT_URL / PORT) ────────────────────
WEKAN_PORT="${PORT:-8080}"
log "Migrating MongoDB → FerretDB. Progress at ${ROOT_URL:-http://localhost:$WEKAN_PORT}"
SOURCE_MONGO_URL="mongodb://127.0.0.1:$SRC_PORT/wekan" \
TARGET_MONGO_URL="mongodb://127.0.0.1:$TGT_PORT/wekan" \
WRITABLE_PATH="$SNAP_COMMON" \
MIGRATION_PORT="$WEKAN_PORT" \
  "$NODE" "$MIGRATOR"
rc=$?

# ── On success: switch the snap to FerretDB ──────────────────────────────────
if [ "$rc" -eq 0 ]; then
  log "Migration succeeded. Switching database=ferretdb."
  touch "$MARKER"
  snapctl set database=ferretdb 2>/dev/null || true
else
  log "ERROR: migration failed (exit $rc). Will retry on next start; MongoDB data kept."
fi

# temp FerretDB + source mongod are stopped by the EXIT trap.
exit 0
